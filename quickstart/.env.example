# ── Point Configuration ──────────────────────────────────────────────
# Copy this file to .env and edit as needed. All values are optional.

# container name
# NAME=point

# Port the app listens on inside the container (default: 8000).
# PORT=8000

# Host port to publish — maps to PORT inside the container.
# APP_PORT=8000

# Where to store your blog data (DB, photos, backups). Default: ./data
# DATA_PATH=./data

# Path to your existing photo library (mounted read-only for import)
# PHOTO_LIBRARY_PATH=/home/yourname/Photos

# Override the auto-generated secret key (optional — one is generated automatically)
# SECRET_KEY=your-random-secret-here

# Enable AI photo analysis with Google Gemini (optional)
# GEMINI_API_KEY=your-gemini-api-key

# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
# LOG_LEVEL=INFO
