# Point Engine Configuration
# Copy this file to .env and adjust values as needed

# =============================================================================
# Application
# =============================================================================
APP_NAME=TheBlog
APP_VERSION=dev
APP_ENV=development
APP_URL=
DEBUG=true

# Serve the debug frontend bundle (frontend/js-debug) instead of the minified
# release bundle. The debug bundle logs plugin mount/unmount, the plugin
# manifest and chunk loads to the browser console, and shows a "debug" badge by
# the version in the admin sidebar. Build-time gated (no runtime switch), so a
# visitor cannot enable it. Requires the debug bundle to have been built
# (scripts/build-js.sh builds it unless BUILD_DEBUG_FRONTEND=0). Off by default.
FRONTEND_DEBUG=false

# IMPORTANT: Change this in production!
SECRET_KEY=change-me-in-production-use-a-long-random-string

# =============================================================================
# Server
# =============================================================================
HOST=0.0.0.0
PORT=8000
DEPLOY_PORT=8000

# =============================================================================
# Database
# =============================================================================
# For Docker: sqlite:/data/point.db
# For local dev: sqlite:./data/point.db
DATABASE_URL=sqlite:./data/point.db

# =============================================================================
# Storage
# =============================================================================
# For Docker: /data
# For local dev: ./data
STORAGE_PATH=./data
STORAGE_QUOTA_MB=5000
MAX_IMAGE_WIDTH=2560
JPEG_QUALITY=85
THUMBNAIL_WIDTH=180
THUMBNAIL_HEIGHT=120
AVATAR_SIZE=80

# =============================================================================
# Blog Settings (defaults, can be overridden in light)
# =============================================================================
BLOG_TITLE=My Photo Blog
BLOG_SUBTITLE=A personal photography journal
AUTHOR_NAME=Photographer
AUTHOR_EMAIL=author@example.com
POSTS_PER_PAGE=10
DEFAULT_LANGUAGE=en
DEFAULT_THEME=auto

# =============================================================================
# Security
# =============================================================================
PASSWORD_MIN_LENGTH=8
SESSION_EXPIRY_HOURS=720
SESSION_EXPIRY_PUBLIC_HOURS=2

# =============================================================================
# Features
# =============================================================================
GOOGLE_ANALYTICS_ID=
FORCE_HTTPS=false
SHOW_VIEW_COUNTS=true

# =============================================================================
# Media Import
# =============================================================================
# Path to a local directory that Point will scan for photos to import.
# Overrides the value set in Settings → Photo Library path.
PHOTO_LIBRARY_PATH=

# =============================================================================
# MCP server (the "mcp" plugin, served at /mcp)
# =============================================================================
# Exposes the blog to AI clients over the Model Context Protocol. The plugin is
# OFF by default — enable it from the admin Plugins page. The endpoint accepts
# either a point API key / session, or an OAuth 2.1 bearer token. Programmatic
# clients should use a point API key (admin → API Keys). Interactive OAuth login
# uses your admin password.
#
# Public HTTPS base URL advertised in OAuth discovery metadata. Falls back to
# APP_URL when empty.
MCP_BASE_URL=

# =============================================================================
# Comments (the "comments" plugin, remark42 at /comments)
# =============================================================================
# The image bundles the remark42 comment engine as a loopback-only sidecar. It
# starts only when BOTH values below are set; without them the blog runs
# unaffected. Enable the plugin from the admin Plugins page to show the widget
# under public posts; moderation lives at /light/comments (Admin → Comments).
#
# Public URL of the comments endpoint: your blog's public URL + /comments.
REMARK_URL=
# remark42 JWT-signing secret — any long random string (openssl rand -hex 32).
# Not the same thing as SECRET_KEY; don't reuse it.
REMARK_SECRET=
# Anonymous commenting (default true). Set false to require OAuth logins,
# configured via remark42 AUTH_* vars — https://remark42.com/docs/
AUTH_ANON=true
# Upgrades: remark42 ships inside the image (rebuild with --pull picks up the
# latest release; pin with the REMARK42_VERSION build arg if one breaks).

# =============================================================================
# Backup
# =============================================================================
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=2
