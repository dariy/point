{
  "project": "point",
  "description": "Self-hosted personal photo blog engine",
  "version": "1.0.0",
  "created": "2026-03-06",
  "languages": [
    "go",
    "javascript",
    "css"
  ],
  "frameworks": {
    "backend": "echo-v4",
    "frontend": "vanilla-js-spa",
    "database": "sqlite-sqlc"
  },
  "test": {
    "runner": "./scripts/run-tests.sh",
    "command": "cd api && go test ./...",
    "coverage_threshold": 80,
    "coverage_flags": [
      "--html"
    ],
    "race_detection": true
  },
  "build": {
    "css": "./scripts/build-css.sh",
    "container": "cd build && ./rebuild.sh",
    "container_engine": "podman"
  },
  "external_tools": {
    "gemini": true,
    "codex": false
  },
  "ci": {
    "provider": "github-actions",
    "workflows_dir": ".github/workflows",
    "workflows": [
      "test.yml",
      "deploy.yml"
    ]
  },
  "branches": {
    "main": "main",
    "naming_convention": "claude/<type>-<description>"
  },
  "serena_projects": {
    "go": "point-go",
    "js": "point-js"
  },
  "paths": {
    "api": "api/",
    "frontend": "frontend/",
    "css_modules": "frontend/css/",
    "scripts": "scripts/",
    "build": "build/",
    "schema": "api/sql/schema.sql",
    "queries": "api/sql/queries.sql",
    "entry": "api/cmd/api/main.go"
  },
  "metaswarm_version": "0.10.0",
  "updated_at": "2026-03-17T00:00:00.000Z"
}
