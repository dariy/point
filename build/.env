# Point Engine Configuration
# Copy this file to .env and adjust values as needed

# =============================================================================
# Application
# =============================================================================
APP_NAME=darii.net
APP_VERSION=dev  # Set by deployment pipeline in production
APP_ENV=development
DEBUG=true

# IMPORTANT: Change this in production!
SECRET_KEY=change-me-in-production-use-a-long-random-string

# =============================================================================
# Server
# =============================================================================
HOST=0.0.0.0
PORT=8000

# =============================================================================
# Database
# =============================================================================
# For Docker: sqlite+aiosqlite:////data/point.db
# For local dev: sqlite+aiosqlite:///./data/point.db
DATABASE_URL=sqlite+aiosqlite:///./data/point.db

# =============================================================================
# Storage
# =============================================================================
# For Docker: /data
# For local dev: ./data
STORAGE_PATH=./data
MAX_UPLOAD_SIZE_MB=500
STORAGE_QUOTA_MB=5000
MAX_IMAGE_WIDTH=2560
JPEG_QUALITY=85
THUMBNAIL_WIDTH=180
THUMBNAIL_HEIGHT=120
AVATAR_SIZE=80

# =============================================================================
# Blog Settings (defaults, can be overridden in light)
# =============================================================================
BLOG_TITLE=darii.net
BLOG_SUBTITLE=A personal point of view
AUTHOR_NAME=Alexei Darii
AUTHOR_EMAIL=spam@darii.net
POSTS_PER_PAGE=6
DEFAULT_LANGUAGE=en
DEFAULT_THEME=auto

# =============================================================================
# Security
# =============================================================================
PASSWORD_MIN_LENGTH=8
SESSION_EXPIRY_HOURS=720
SESSION_EXPIRY_PUBLIC_HOURS=2

# =============================================================================
# Features
# =============================================================================
ENABLE_ANALYTICS=false
GOOGLE_ANALYTICS_ID=
FORCE_HTTPS=false
SHOW_VIEW_COUNTS=true

# =============================================================================
# Media Import
# =============================================================================
# Path to a local directory that Point will scan for photos to import.
# Overrides the value set in Settings → Photo Library path.
MEDIA_IMPORT_PATH=

# =============================================================================
# Backup
# =============================================================================
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=2
