# Point — Production Environment
# Copy to .env in the same directory as docker-compose.yml and adjust.

# =============================================================================
# Required in production
# =============================================================================

# Generate with: openssl rand -base64 48
# Leave unset to let Point generate and persist one automatically.
SECRET_KEY=

# Gemini API key for AI-assisted media analysis (optional)
GEMINI_API_KEY=

# =============================================================================
# Server
# =============================================================================
HOST=0.0.0.0
PORT=8000
DEPLOY_PORT=8000

# =============================================================================
# Database & Storage (usually managed by container volumes — rarely change)
# =============================================================================
DATABASE_URL=sqlite:/data/point.db
STORAGE_PATH=/data

# =============================================================================
# Media Import (optional)
# =============================================================================
# Path inside the container where a read-only photo library is mounted.
# Set this when using PHOTO_LIBRARY_PATH in docker-compose.yml.
MEDIA_IMPORT_PATH=

# =============================================================================
# Thumbnail & image settings
# =============================================================================
THUMBNAIL_WIDTH=400
THUMBNAIL_HEIGHT=300
JPEG_QUALITY=85
MAX_UPLOAD_SIZE_MB=50

# =============================================================================
# Session
# =============================================================================
SESSION_EXPIRY_HOURS=720
