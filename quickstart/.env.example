# ── Point Configuration ──────────────────────────────────────────────
# This file is optional — docker compose up -d works without it.
# To customize, copy to .env and uncomment the values you want to change.

# container name
# NAME=point

# Port the app listens on inside the container (default: 8000).
# PORT=8000

# Host port to publish — maps to PORT inside the container.
# APP_PORT=8000

# Where to store your blog data (DB, photos, backups). Default: ./data
# DATA_PATH=./data

# Path to your existing photo library (mounted read-only for import)
# PHOTO_LIBRARY_PATH=/home/yourname/Photos

# Override the auto-generated secret key (optional — one is generated automatically)
# SECRET_KEY=your-random-secret-here

# Enable AI photo analysis with Google Gemini (optional)
# GEMINI_API_KEY=your-gemini-api-key

# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
# LOG_LEVEL=INFO

# Comments on posts via the bundled remark42 engine (optional).
# Set BOTH values, `docker compose up -d`, then enable the "Comments" plugin
# in Admin → Plugins. Moderate from Admin → Comments.
# REMARK_URL is your blog's public URL + /comments; REMARK_SECRET is any long
# random string (e.g. `openssl rand -hex 32`).
# REMARK_URL=https://blog.example.com/comments
# REMARK_SECRET=
