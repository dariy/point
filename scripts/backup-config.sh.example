#!/bin/bash
# Configuration for backup/restore scripts
# Copy this file to backup-config.sh and adjust the values
# Then source it before running the scripts:
#   source scripts/backup-config.sh
#   ./scripts/pull-from-production.sh

# ==================================================
# Production Server Configuration
# ==================================================

# Production server SSH connection
# Format: user@hostname or user@ip
export PROD_HOST="user@your-production-server.com"

# Container name on production (as shown in 'docker ps')
export PROD_CONTAINER="photo-blog"

# Docker command prefix on production
# Leave empty if user is in docker group
# Set to "sudo" if docker requires root privileges
export PROD_SUDO=""
# export PROD_SUDO="sudo"  # Uncomment if you need sudo

# ==================================================
# Local Container Configuration
# ==================================================

# Local container name on lab machine (as shown in 'docker ps')
export LOCAL_CONTAINER="photo-blog"

# Docker command prefix on local machine
# Leave empty if user is in docker group
# Set to "sudo" if docker requires root privileges
export LOCAL_SUDO=""
# export LOCAL_SUDO="sudo"  # Uncomment if you need sudo

# ==================================================
# Backup Storage
# ==================================================

# Local backup directory on lab machine
export LOCAL_BACKUP_DIR="./backups"
