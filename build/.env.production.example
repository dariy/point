# Point - Production Environment Configuration
# Copy this file to .env and configure with your production values

# ====================================
# Environment
# ====================================
ENVIRONMENT=production

# ====================================
# Security Settings (REQUIRED)
# ====================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY_64_CHARACTERS_OR_MORE
SESSION_SECRET=CHANGE_THIS_TO_A_DIFFERENT_RANDOM_SECRET_KEY

# ====================================
# Database
# ====================================
DATABASE_URL=sqlite+aiosqlite:////data/point.db

# ====================================
# Blog Configuration
# ====================================
BLOG_TITLE=My Photo Blog
BLOG_DESCRIPTION=A personal photography journal
BLOG_AUTHOR=Your Name
BLOG_URL=https://yourdomain.com

# Email for light notifications (optional)
light_EMAIL=light@yourdomain.com

# ====================================
# Media Settings
# ====================================
# Max file upload size in bytes (default: 50MB)
MAX_UPLOAD_SIZE=52428800

# Total storage quota in bytes (default: 10GB)
STORAGE_QUOTA=10737418240

# Image quality for JPEG compression (1-100, default: 85)
IMAGE_QUALITY=85

# Maximum image dimension in pixels (default: 2560)
MAX_IMAGE_DIMENSION=2560

# Thumbnail size (default: 180x120)
THUMBNAIL_WIDTH=180
THUMBNAIL_HEIGHT=120

# ====================================
# Performance & Caching
# ====================================
# Enable file-based caching
CACHE_ENABLED=true

# Cache TTL in seconds (default: 1 hour)
CACHE_TTL=3600

# Number of posts per page (default: 12)
POSTS_PER_PAGE=12

# ====================================
# Media Import
# ====================================
# Path to a local directory that Point will scan for photos to import.
# Overrides the value set in Settings → Photo Library path.
MEDIA_IMPORT_PATH=

# ====================================
# Backup Settings
# ====================================
# Enable automated backups
BACKUP_ENABLED=true

# Backup schedule (cron format, default: 2 AM daily)
BACKUP_SCHEDULE=0 2 * * *

# Number of days to retain backups (default: 30)
BACKUP_RETENTION_DAYS=30

# Optional: S3/Backblaze B2 backup (for off-site backups)
# BACKUP_S3_ENABLED=false
# BACKUP_S3_BUCKET=my-blog-backups
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_ACCESS_KEY=your_access_key
# BACKUP_S3_SECRET_KEY=your_secret_key
# BACKUP_S3_ENDPOINT=https://s3.amazonaws.com

# ====================================
# Session Settings
# ====================================
# Session expiry in seconds (default: 30 days)
SESSION_EXPIRY=2592000

# Cookie secure flag (must be true for HTTPS)
COOKIE_SECURE=true

# Cookie SameSite setting (Strict, Lax, or None)
COOKIE_SAMESITE=Lax

# ====================================
# Logging
# ====================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file locations
LOG_FILE=/data/logs/app.log
ERROR_LOG_FILE=/data/logs/error.log

# Log rotation
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ====================================
# Rate Limiting (Optional)
# ====================================
# Enable rate limiting for login attempts
RATE_LIMIT_ENABLED=true

# Maximum login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in seconds (default: 15 minutes)
LOCKOUT_DURATION=900

# ====================================
# SEO & RSS
# ====================================
# Number of posts in RSS feed (default: 20)
RSS_FEED_COUNT=20

# Include full content in RSS (true) or excerpts (false)
RSS_FULL_CONTENT=false

# ====================================
# Docker & Deployment
# ====================================
# GitHub Container Registry (for CI/CD)
GITHUB_REPOSITORY=dariy/point

# Data directory path (for production volume mount)
DATA_PATH=/var/lib/point/data

# HTTP and HTTPS ports for nginx
HTTP_PORT=80
HTTPS_PORT=443

# ====================================
# Monitoring & Health Checks
# ====================================
# Enable health check endpoint
HEALTH_CHECK_ENABLED=true

# Health check database query timeout (seconds)
HEALTH_CHECK_DB_TIMEOUT=5

# ====================================
# Advanced Settings (Optional)
# ====================================
# CORS settings (if exposing API to other domains)
# CORS_ENABLED=false
# CORS_ORIGINS=https://example.com,https://www.example.com

# Custom theme (if using custom CSS)
# CUSTOM_THEME_PATH=/data/custom-theme.css

# Enable debug mode (NEVER in production!)
# DEBUG=false

# ====================================
# GitHub Actions Secrets (Set in GitHub Repository)
# ====================================
# These should be configured as GitHub Secrets, not in .env file:
#
# DEPLOY_HOST=yourdomain.com
# DEPLOY_USER=deploy
# DEPLOY_SSH_KEY=<your-private-ssh-key>
# DEPLOY_SSH_PORT=22
# DEPLOY_PATH=/opt/point
# CODECOV_TOKEN=<your-codecov-token>
